# MongoDB Atlas connection string.
# On networks where DNS SRV lookups are blocked, use the standard (non +srv)
# connection string: mongodb://user:pass@host1:27017,host2:27017/shopnova?ssl=true&replicaSet=...&authSource=admin
MONGODB_URI=

# Base URL used by the service layer for absolute fetches (Server Components).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
