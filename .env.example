# MongoDB Atlas connection string.
# On networks where DNS SRV lookups are blocked, use the standard (non +srv)
# connection string: mongodb://user:pass@host1:27017,host2:27017/shopnova?ssl=true&replicaSet=...&authSource=admin
MONGODB_URI=

# Base URL used by the service layer for absolute fetches (Server Components).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Pexels (auto images for the seed). Free key at pexels.com/api.
# Without a key the seed falls back to placehold.co images.
PEXELS_API_KEY=

# Email (Gmail SMTP). MAIL_PASS must be a Google "App Password" (16 chars),
# NOT your normal Gmail password. Requires 2-step verification enabled.
MAIL_USER=
MAIL_PASS=

# Daily sales report cron.
CRON_SECRET=
REPORT_EMAIL=

# Gemini (AI report). FREE key at aistudio.google.com (not the chat subscription).
GEMINI_API_KEY=
